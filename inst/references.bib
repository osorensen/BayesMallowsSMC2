  doi = {10.1007/11537311_39},
  abstract = {Given a poset \${\textbackslash}mathcal\{P\}\$, several algorithms have been proposed for generating all linear extensions of \${\textbackslash}mathcal\{P\}\$. The fastest known algorithm generates each linear extension in constant time ``on average''. In this paper we give a simple algorithm which generates each linear extension in constant time ``in worst case''. The known algorithm generates each linear extension exactly twice and output one of them, while our algorithm generates each linear extension exactly once.},
