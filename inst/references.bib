@article{batesFastElegantNumerical2013,
  title = {Fast and {{Elegant Numerical Linear Algebra Using}} the {{RcppEigen Package}}},
  author = {Bates, Douglas M and Eddelbuettel, Dirk},
  year = {2013},
  month = feb,
  journal = {Journal of Statistical Software},
  volume = {52},
