  title = {Multilevel Models with Multivariate Mixed Response Types},
  author = {Goldstein, Harvey and Carpenter, James and Kenward, Michael G and Levin, Kate A},
  year = {2009},
  month = oct,
  journal = {Statistical Modelling},
