@inproceedings{onoConstantTimeGeneration2005,
  title = {Constant {{Time Generation}} of {{Linear Extensions}}},
  booktitle = {Fundamentals of {{Computation Theory}}},
  author = {Ono, Akimitsu and Nakano, Shin-ichi},
